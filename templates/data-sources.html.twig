{#
/**
 * @file
 * Template for Data Sources page.
 *
 * Available variables:
 * - grouped_data: Array of metrics grouped by dimension and category
 * - dimension_names: Array of dimension display names
 * - unique_references: Array of unique reference URLs with counts
 * - total_metrics: Total count of metrics with references
 * - metrics_by_dimension: Count of metrics per dimension
 */
#}

<div class="data-sources-page container my-5">
  {# Hero Section #}
  <div class="hero-section bg-light py-5 mb-5 rounded">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-8 mx-auto text-center">
          <h1 class="display-4 mb-3">Data Sources & Research References</h1>
          <p class="lead text-muted mb-4">
            Our safety assessment is built on peer-reviewed research and validated data sources. 
            Every metric is backed by academic studies, government statistics, or established psychological frameworks.
          </p>
          <div class="row mt-4">
            <div class="col-md-4">
              <div class="stat-card p-3 bg-white rounded shadow-sm">
                <div class="h2 mb-0 text-primary">{{ total_metrics }}</div>
                <div class="small text-muted">Referenced Metrics</div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="stat-card p-3 bg-white rounded shadow-sm">
                <div class="h2 mb-0 text-success">{{ unique_references|length }}</div>
                <div class="small text-muted">Unique Sources</div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="stat-card p-3 bg-white rounded shadow-sm">
                <div class="h2 mb-0 text-info">{{ grouped_data|length }}</div>
                <div class="small text-muted">Dimensions</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# Main Content #}
  <div class="container mb-5">
    {# Research Transparency Statement #}
    <div class="alert alert-info mb-5">
      <h5 class="alert-heading">
        <i class="fas fa-info-circle me-2"></i>Research Transparency & Methodology
      </h5>
      <p class="mb-2">
        We believe in complete transparency about our data sources. Each metric in our assessment is grounded in 
        established research from psychology, sociology, public health, and related fields. Citations are provided 
        in APA format where available, with direct links to original sources.
      </p>
      <p class="mb-0">
        <strong>Normalization:</strong> All 1,117 metrics across the seven dimensions of safety have been normalized using z-score methodology, mapping population distributions to a 0-100 scale where 50 represents the mean, 0 represents three standard deviations below, and 100 represents three standard deviations above.
      </p>
    </div>

    {# References by Dimension #}
    <div class="references-by-dimension">
      <h2 class="h3 mb-4">
        <i class="fas fa-book me-2 text-primary"></i>References by Dimension
      </h2>
      <p class="text-muted mb-4">Expand each dimension to view research sources organized by category.</p>

      <div class="accordion" id="dimensionsAccordion">
        {% for dimension, categories in grouped_data %}
          <div class="accordion-item mb-3 border rounded shadow-sm">
            <h2 class="accordion-header" id="heading-{{ dimension }}">
              <button class="accordion-button collapsed" 
                      type="button" 
                      data-bs-toggle="collapse" 
                      data-bs-target="#collapse-{{ dimension }}" 
                      aria-expanded="false" 
                      aria-controls="collapse-{{ dimension }}">
                <div class="d-flex align-items-center w-100">
                  <img src="/themes/custom/forseti/images/logos/originals/forseti_{{ dimension|lower }}.png" 
                       alt="{{ dimension_names[dimension] }}" 
                       class="me-3" 
                       style="height: 32px; width: auto;">
                  <div class="flex-grow-1">
                    <strong class="fs-5">{{ dimension_names[dimension] }}</strong>
                    <span class="badge bg-primary ms-3">{{ metrics_by_dimension[dimension] }} metrics</span>
                  </div>
                </div>
              </button>
            </h2>
            
            <div id="collapse-{{ dimension }}" 
                 class="accordion-collapse collapse" 
                 aria-labelledby="heading-{{ dimension }}" 
                 data-bs-parent="#dimensionsAccordion">
              <div class="accordion-body">
                
                {# Categories within dimension #}
                <div class="accordion" id="categories-{{ dimension }}">
                  {% for category, metrics in categories %}
                    <div class="accordion-item mb-2">
                      <h3 class="accordion-header" id="heading-{{ dimension }}-{{ loop.index }}">
                        <button class="accordion-button collapsed bg-light" 
                                type="button" 
                                data-bs-toggle="collapse" 
                                data-bs-target="#collapse-{{ dimension }}-{{ loop.index }}" 
                                aria-expanded="false">
                          <div class="d-flex align-items-center w-100">
                            <i class="fas fa-folder-open me-2 text-warning"></i>
                            <strong>{{ category }}</strong>
                            <span class="badge bg-secondary ms-3">{{ metrics|length }} metrics</span>
                          </div>
                        </button>
                      </h3>
                      
                      <div id="collapse-{{ dimension }}-{{ loop.index }}" 
                           class="accordion-collapse collapse" 
                           aria-labelledby="heading-{{ dimension }}-{{ loop.index }}" 
                           data-bs-parent="#categories-{{ dimension }}">
                        <div class="accordion-body bg-light">
                          
                          {# Metrics in category #}
                          <div class="metrics-list">
                            {% for metric in metrics %}
                              <div class="metric-card card mb-3">
                                <div class="card-body">
                                  <div class="d-flex align-items-start justify-content-between mb-2">
                                    <h4 class="h6 mb-0">
                                      {{ metric.description }}
                                    </h4>
                                    <span class="badge bg-secondary ms-2">#{{ metric.id }}</span>
                                  </div>
                                  
                                  <p class="small text-muted mb-2">
                                    <i class="fas fa-code me-1"></i>
                                    <code>{{ metric.name }}</code>
                                  </p>
                                  
                                  {% if metric.citation %}
                                    <div class="citation-box mb-2 p-2 border-start border-3 border-secondary bg-white">
                                      <small class="text-muted">{{ metric.citation|raw }}</small>
                                    </div>
                                  {% endif %}
                                  
                                  {% if metric.url %}
                                    <a href="{{ metric.url }}" 
                                       target="_blank" 
                                       rel="noopener noreferrer" 
                                       class="btn btn-sm btn-outline-primary mt-2">
                                      <i class="fas fa-external-link-alt me-1"></i>View Source
                                    </a>
                                  {% endif %}
                                </div>
                              </div>
                            {% endfor %}
                          </div>
                          
                        </div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
                
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {# Top References Section #}
    <div class="top-references mt-5 pt-5 border-top">
      <h2 class="mb-4">Most Frequently Referenced Sources</h2>
      <p class="text-muted mb-4">
        These sources are cited across multiple metrics in our assessment:
      </p>
      
      <div class="references-list">
        {% set sorted_refs = unique_references|sort((a, b) => b.count <=> a.count) %}
        {% for ref in sorted_refs|slice(0, 20) %}
          <div class="reference-item card mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                  {% if ref.citation %}
                    <p class="mb-2">{{ ref.citation|raw }}</p>
                  {% endif %}
                  {% if ref.url %}
                    <a href="{{ ref.url }}" 
                       target="_blank" 
                       rel="noopener noreferrer" 
                       class="small text-primary">
                      <i class="fas fa-link me-1"></i>{{ ref.url }}
                    </a>
                  {% endif %}
                </div>
                <div class="ms-3">
                  <span class="badge bg-primary">
                    {{ ref.count }} metric{{ ref.count > 1 ? 's' : '' }}
                  </span>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {# Methodology Note #}
    <div class="alert alert-light mt-5">
      <h5 class="mb-3">About Our Research Methodology</h5>
      <p>
        Our assessment framework draws from multiple validated sources:
      </p>
      <ul class="mb-3">
        <li><strong>Peer-Reviewed Research:</strong> Academic journals in psychology, sociology, and public health</li>
        <li><strong>Government Statistics:</strong> CDC, Census Bureau, BLS, and other federal agencies</li>
        <li><strong>Clinical Assessments:</strong> Validated psychological instruments (PHQ-9, GAD-7, etc.)</li>
        <li><strong>WHO Guidelines:</strong> World Health Organization standards for wellbeing metrics</li>
        <li><strong>NIH Data:</strong> National Institutes of Health research databases</li>
      </ul>
      <p class="mb-0">
        <strong>Note:</strong> Some metrics combine multiple sources or use standardized scales. 
        Where multiple sources inform a single metric, the primary reference is listed.
      </p>
    </div>
  </div>
</div>
