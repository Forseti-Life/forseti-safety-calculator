<?php

/**
 * @file
 * Contains safety_calculator.module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function safety_calculator_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.safety_calculator':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The Safety Calculator module provides comprehensive safety score calculations and risk assessment for locations using H3 geospatial data.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Calculate safety scores for specific locations') . '</li>';
      $output .= '<li>' . t('Aggregate crime data across H3 hexagons') . '</li>';
      $output .= '<li>' . t('Provide risk assessment based on historical data') . '</li>';
      $output .= '<li>' . t('Time-based safety analysis (day/night, time of day)') . '</li>';
      $output .= '</ul>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function safety_calculator_theme($existing, $type, $theme, $path) {
  return [
    'individual_metrics_profile' => [
      'variables' => [
        'user' => NULL,
        'assessment' => NULL,
        'dimensions' => [],
        'has_responses' => FALSE,
      ],
      'template' => 'individual-metrics-profile',
    ],
    'population_benchmarks' => [
      'variables' => [
        'dimensions' => [],
        'dimension_scores' => [],
      ],
      'template' => 'population-benchmarks',
    ],
    'data_sources' => [
      'variables' => [
        'grouped_data' => [],
        'dimension_names' => [],
        'unique_references' => [],
        'total_metrics' => 0,
        'metrics_by_dimension' => [],
      ],
      'template' => 'data-sources',
    ],
  ];
}

